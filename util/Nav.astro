---
    const nav = [];
    const {posts} = Astro.props;
    const visiblePosts = posts.filter((post) => post.frontmatter?.nav !== false);
    const rootOrder = [
        '/',
        '/the-fathers-house',
        '/the-unknown-god',
        '/sermons',
        '/mission-statement',
        '/contact-us'
    ];
    const normalizeUrl = (url: string) => url !== '/' && url.endsWith('/') ? url.slice(0, -1) : url;

    const getParentPath = (paths: string[], deep: number) => {
        return '/' + paths.slice(0, deep).join('/')
    }

    const findParent = (path: string[]) => {
        let iterateNav = nav;
        path.forEach((i, index) => {
            const found = iterateNav.find(j => j.url === getParentPath(path, index + 1));
            if (!found) { return }
            iterateNav = found.children;
        })
        return iterateNav;
    }


    visiblePosts.sort((a,b) => a.url.length < b.url.length ? -1 : 1).forEach(i => {
        const splitUrl = i.url.split('/');
        const hasParents = splitUrl.length > 2;
        let parent = nav;
        if (hasParents) { 
            const parentPath = splitUrl.slice(1, splitUrl.length - 1);
            parent = findParent(parentPath)
        }
        parent.push({label: i.frontmatter.title, url: i.url || '/', children: []})
    });

    nav.sort((a, b) => {
        const aIndex = rootOrder.indexOf(normalizeUrl(a.url));
        const bIndex = rootOrder.indexOf(normalizeUrl(b.url));

        if (aIndex !== -1 || bIndex !== -1) {
            if (aIndex === -1) return 1;
            if (bIndex === -1) return -1;
            return aIndex - bIndex;
        }

        return a.label.localeCompare(b.label);
    });
---

<nav aria-label="Primary" class="w-auto lg:w-full">
    <details class="group relative lg:hidden">
        <summary class="inline-flex min-h-11 items-center gap-3 rounded-full border border-white/25 px-4 py-2 font-display text-sm uppercase tracking-[0.28em] text-white [::-webkit-details-marker]:hidden">
            <span>Menu</span>
            <span aria-hidden="true" class="text-lg leading-none">+</span>
        </summary>

        <div class="absolute right-0 top-full z-30 mt-4 w-[min(22rem,calc(100vw-48px))] rounded-2xl border border-white/10 bg-black/85 text-left shadow-xl shadow-black/30">
            <ul class="m-0 list-none p-2">
                {nav.map((item) =>
                    <li class="border-b border-white/10 last:border-b-0">
                        {item.children.length > 0 ? (
                            <details class="group/submenu">
                                <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between px-4 py-3 font-medium uppercase text-white [::-webkit-details-marker]:hidden">
                                    <span>{item.label}</span>
                                    <span aria-hidden="true" class="text-lg leading-none">+</span>
                                </summary>
                                <div class="border-t border-white/10 bg-white/5 px-2 py-2">
                                    <a href={item.url} class="block rounded-xl px-3 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-white hover:bg-white/10">
                                        Overview
                                    </a>
                                    <ul class="m-0 list-none p-0">
                                        {item.children.map((child) =>
                                            <li class="mt-1">
                                                {child.children.length > 0 ? (
                                                    <details>
                                                        <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between rounded-xl px-3 py-2 text-sm text-white/90 [::-webkit-details-marker]:hidden">
                                                            <span>{child.label}</span>
                                                            <span aria-hidden="true" class="text-base leading-none">+</span>
                                                        </summary>
                                                        <div class="mt-1 rounded-xl bg-black/25 px-2 py-2">
                                                            <a href={child.url} class="block rounded-lg px-3 py-2 text-sm font-medium text-white hover:bg-white/10">
                                                                Overview
                                                            </a>
                                                            <ul class="m-0 list-none p-0">
                                                                {child.children.map((grandchild) =>
                                                                    <li class="mt-1">
                                                                        {grandchild.children.length > 0 ? (
                                                                            <details>
                                                                                <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2 text-sm text-white/80 [::-webkit-details-marker]:hidden">
                                                                                    <span>{grandchild.label}</span>
                                                                                    <span aria-hidden="true" class="text-base leading-none">+</span>
                                                                                </summary>
                                                                                <div class="mt-1 rounded-lg bg-black/25 px-2 py-2">
                                                                                    <a href={grandchild.url} class="block rounded-lg px-3 py-2 text-sm font-medium text-white hover:bg-white/10">
                                                                                        Overview
                                                                                    </a>
                                                                                    <ul class="m-0 list-none p-0">
                                                                                        {grandchild.children.map((leaf) =>
                                                                                            <li class="mt-1">
                                                                                                <a href={leaf.url} class="block rounded-lg px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white">
                                                                                                    {leaf.label}
                                                                                                </a>
                                                                                            </li>
                                                                                        )}
                                                                                    </ul>
                                                                                </div>
                                                                            </details>
                                                                        ) : (
                                                                            <a href={grandchild.url} class="block rounded-lg px-3 py-2 text-sm text-white/80 hover:bg-white/10 hover:text-white">
                                                                                {grandchild.label}
                                                                            </a>
                                                                        )}
                                                                    </li>
                                                                )}
                                                            </ul>
                                                        </div>
                                                    </details>
                                                ) : (
                                                    <a href={child.url} class="block rounded-xl px-3 py-2 text-sm text-white/90 hover:bg-white/10 hover:text-white">
                                                        {child.label}
                                                    </a>
                                                )}
                                            </li>
                                        )}
                                    </ul>
                                </div>
                            </details>
                        ) : (
                            <a href={item.url} class="block min-h-11 rounded-xl px-4 py-3 font-medium uppercase text-white hover:bg-white/10">
                                {item.label}
                            </a>
                        )}
                    </li>
                )}
            </ul>
        </div>
    </details>

    <ul class="m-0 hidden list-none items-center justify-center whitespace-nowrap p-0 lg:flex">
        {nav.map((item) => 
            <li class="group relative inline-block font-medium uppercase">
                <a href={item.url} class="inline-block px-3 text-white hover:opacity-80">{item.label}</a>
                {item.children.length > 0 && <ul class="hidden min-w-[250px] bg-white text-left text-black group-hover:block lg:absolute lg:left-0 lg:top-full lg:before:absolute lg:before:bottom-full lg:before:left-0 lg:before:block lg:before:h-5 lg:before:w-full lg:before:content-['']">
                    {item.children.map(item => 
                        <li class="group/item relative block">
                            <a href={item.url} class="block px-3 py-2 hover:bg-gray-100">{item.label}</a>
                            {item.children.length > 0 && <ul class="hidden min-w-[250px] bg-white text-left text-black group-hover/item:block lg:absolute lg:left-full lg:top-0">
                                {item.children.map(item => 
                                    <li class="group/subitem relative block">
                                        <a href={item.url} class="block px-3 py-2 hover:bg-gray-100">{item.label}</a>
                                        {item.children.length > 0 && <ul class="hidden min-w-[250px] bg-white text-left text-black group-hover/subitem:block lg:absolute lg:left-full lg:top-0">
                                            {item.children.map(item => 
                                                <li class="block">
                                                    <a href={item.url} class="block px-3 py-2 hover:bg-gray-100">{item.label}</a>
                                                </li>
                                            )}
                                        </ul>}
                                    </li>
                                )}
                            </ul>}
                        </li>
                    )}
                </ul>}
            </li>
        )}
    </ul>
</nav>

---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---

<Base title="CCEDS">
  <Hero />

  <section class="feature-strip">
    <div class="wrapper feature-grid">
      <article>
        <i class="fas fa-briefcase" aria-hidden="true"></i>
        <h2>Commercial Solutions</h2>
        <p>A small business helping out other small businesses.</p>
      </article>
      <article>
        <i class="fas fa-shield-alt" aria-hidden="true"></i>
        <h2>Insured &amp; Reliable</h2>
        <p>We handle the logistics so your delivery arrives safely and on time.</p>
      </article>
      <article>
        <i class="fas fa-house" aria-hidden="true"></i>
        <h2>Family Owned</h2>
        <p>Family operated since the early beginnings, with service built on trust.</p>
      </article>
      <article>
        <i class="fas fa-users" aria-hidden="true"></i>
        <h2>Community Driven</h2>
        <p>The success of our business depends on the success of the community.</p>
      </article>
    </div>
  </section>

  <section id="about" class="about-section">
    <div class="wrapper about-grid">
      <div class="about-image" aria-hidden="true"></div>
      <div class="about-copy">
        <h2>About Us</h2>
        <p>
          Coles County Express Delivery Services was built to help local families
          and businesses move important cargo without overcomplicating the
          process. The original site described the company as a practical,
          community-focused delivery partner, and that is the part preserved
          here.
        </p>
        <p>
          From same-day pickups to planned delivery runs, the emphasis is on
          dependable communication and flexible service for shipments that do not
          fit a standard courier workflow.
        </p>
        <a class="button-link" href="/contact">Contact Us</a>
      </div>
    </div>
  </section>

  <section id="services" class="services-section">
    <div class="wrapper">
      <h2>Some Things We Deliver</h2>
      <div class="services-grid">
        <article>
          <i class="fas fa-dog" aria-hidden="true"></i>
          <h3>Pets</h3>
        </article>
        <article>
          <i class="fas fa-car" aria-hidden="true"></i>
          <h3>Vehicles</h3>
        </article>
        <article>
          <i class="fas fa-shopping-basket" aria-hidden="true"></i>
          <h3>Groceries</h3>
        </article>
        <article>
          <i class="fas fa-suitcase-rolling" aria-hidden="true"></i>
          <h3>Luggage</h3>
        </article>
        <article>
          <i class="fas fa-hard-hat" aria-hidden="true"></i>
          <h3>Building Material</h3>
        </article>
        <article>
          <i class="fas fa-calendar" aria-hidden="true"></i>
          <h3>Appliances</h3>
        </article>
      </div>
    </div>
  </section>
</Base>

<section id="schedule" class="relative bg-[url('/hero.jpg')] bg-cover bg-center">
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(0,0,0,0.84)_0%,rgba(0,0,0,0.58)_44%,rgba(0,0,0,0.12)_100%)]"></div>
  <div class="relative mx-auto grid min-h-[42rem] w-[min(1200px,calc(100%-2rem))] items-center gap-12 py-16 lg:grid-cols-[minmax(0,1.2fr)_360px]">
    <div class="text-white">
      <span class="mb-3 block text-[1.1rem] text-white/70">Got something you need shipped?</span>
      <h1 class="mb-4 text-[clamp(2.4rem,5vw,4.8rem)] leading-[0.96] uppercase">Let us ship it for you</h1>
      <p class="max-w-[42rem] text-[1.1rem] leading-7">
        Local and regional delivery support for businesses, households, and
        time-sensitive runs that cannot wait on standard freight.
      </p>
    </div>
    <div class="relative z-1 rounded-2xl bg-white/95 p-6 shadow-[0_28px_60px_rgba(0,0,0,0.18)]">
      <p class="mb-4 mt-0 text-center text-2xl font-bold leading-7">Get a Quote</p>
      <form>
        <input type="text" placeholder="Pickup Location" class="mb-4 w-full rounded-xl border border-[#ddd] bg-[#fafafa] px-4 py-4" />
        <input type="text" placeholder="Destination" class="mb-4 w-full rounded-xl border border-[#ddd] bg-[#fafafa] px-4 py-4" />
        <input type="text" placeholder="Estimated Distance" class="mb-4 w-full rounded-xl border border-[#ddd] bg-[#fafafa] px-4 py-4" />
        <button type="button" class="inline-flex w-full items-center justify-center rounded-full border border-cceds-primary px-6 py-4 font-bold uppercase text-cceds-primary transition hover:bg-cceds-primary hover:text-white">Request Quote</button>
      </form>
    </div>
  </div>
</section>

---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title = 'Highline Media',
  description = 'Highline Media captures family, social, business, and event moments through video-first storytelling.'
} = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-highline-ink scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/logo.png" />
    <title>{title}</title>
  </head>
  <body class="m-0 min-h-screen bg-[radial-gradient(circle_at_top,rgba(245,190,103,0.14),transparent_30%),linear-gradient(180deg,#0c1726_0%,#08111d_38%,#050a12_100%)] font-sans text-highline-copy antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

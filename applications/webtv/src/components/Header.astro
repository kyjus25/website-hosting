---
const { pathname } = Astro.url;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/news', label: 'News' },
  { href: '/live', label: 'Live' },
  { href: '/donate', label: 'Donate' },
  { href: '/contact', label: 'Contact' }
];
---

<header class="pt-4">
  <div class="mx-auto flex w-[min(1200px,calc(100%-2rem))] flex-col items-stretch justify-between gap-4 bg-[#444] px-6 py-5 text-white md:flex-row md:items-center">
    <a href="/" class="inline-flex">
      <img src="/WebTv logo.png" alt="WebTV logo" class="block max-w-[12.5rem]" />
    </a>
    <input type="text" placeholder="Search for a video or post..." aria-label="Search" class="w-full rounded-full border-0 bg-white/20 px-4 py-4 text-white placeholder:text-white/80 md:w-[min(22rem,100%)]" />
  </div>
  <nav class="border-b border-black bg-white" aria-label="Primary">
    <ul class="mx-auto flex w-[min(1200px,calc(100%-2rem))] flex-col p-0 md:flex-row">
      {nav.map((item) => (
        <li>
          <a href={item.href} class:list={['block px-7 py-5 transition hover:text-webtv-accent', pathname === item.href && 'text-webtv-accent']}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

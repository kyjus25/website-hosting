---
import Base from '../layouts/Base.astro';
---

<Base title="WebTV | Contact">
  <article class="mt-4 border border-webtv-border bg-webtv-card p-6">
    <h1 class="mt-0 text-4xl font-semibold">Contact Us</h1>
    <form class="grid gap-4">
      <input type="text" placeholder="Name" class="w-full border border-webtv-border bg-white px-4 py-4" />
      <input type="email" placeholder="Email" class="w-full border border-webtv-border bg-white px-4 py-4" />
      <textarea rows="6" placeholder="Message" class="w-full border border-webtv-border bg-white px-4 py-4"></textarea>
      <button type="button" class="inline-flex items-center justify-center bg-webtv-accent px-5 py-3 text-white">Send Message</button>
    </form>
  </article>
</Base>

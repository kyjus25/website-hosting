---
import Base from '../layouts/Base.astro';
---

<Base title="WebTV | About">
  <article class="mt-4 border border-webtv-border bg-webtv-card p-6">
    <h1 class="mt-0 text-4xl font-semibold">About</h1>
    <p class="leading-7">
      This page existed as a dynamic slug in the legacy application. Its body
      copy was not committed with the repo, so this migration preserves the route
      and layout while the missing editorial content is restored.
    </p>
  </article>
</Base>

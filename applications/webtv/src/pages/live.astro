---
import Base from '../layouts/Base.astro';
---

<Base title="WebTV | Live">
  <article class="card">
    <h1>Live</h1>
    <p>
      The embedded HLS player in the legacy branch was commented out. This page
      keeps the route active and preserves the committed media asset while a new
      live source is wired in.
    </p>
    <video controls preload="metadata" class="video-frame">
      <source src="/USA Project.mp4" type="video/mp4" />
      Your browser does not support HTML video.
    </video>
  </article>
</Base>

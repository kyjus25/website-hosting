---
import Base from '../layouts/Base.astro';
---

<Base title="WebTV | Mission">
  <article class="mt-4 border border-webtv-border bg-webtv-card p-6">
    <h1 class="mt-0 text-4xl font-semibold">Our Mission</h1>
    <p class="leading-7">
      The mission page was one of the dynamic WebTV routes. It is now isolated in
      this Astro app so the site can evolve without the missing Svelte store and
      backend dependency.
    </p>
  </article>
</Base>

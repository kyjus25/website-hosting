---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title = 'LED' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css"
    />
    <title>{title}</title>
  </head>
  <body class="m-0 bg-[radial-gradient(circle_at_top,rgba(244,224,77,0.16),transparent_38%),linear-gradient(180deg,#121212_0%,#000000_100%)] font-sans text-white">
    <Header />
    <main class="min-h-[calc(100vh-164px)]">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
import Base from '../layouts/Base.astro';
---

<Base title="LED | Portfolio">
  <section class="portfolio-page wrapper">
    <div class="page-heading">
      <p class="eyebrow">Portfolio</p>
      <h1>Visual references from the legacy branch</h1>
      <p>
        The previous site linked to portfolio content without a committed data
        source. These retained assets provide a stable base for rebuilding that
        gallery.
      </p>
    </div>

    <div class="portfolio-grid">
      <figure class="portfolio-card">
        <img src="/led stage show.jpeg" alt="Stage show lighting" />
        <figcaption>Stage show setup</figcaption>
      </figure>
      <figure class="portfolio-card">
        <img src="/led-pic-bg.jpg" alt="Lighting design background" />
        <figcaption>Production background</figcaption>
      </figure>
      <figure class="portfolio-card">
        <img src="/led.png" alt="LED brand mark" />
        <figcaption>Brand identity</figcaption>
      </figure>
    </div>
  </section>
</Base>

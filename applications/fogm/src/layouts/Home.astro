---
import Base from './Base.astro';
const { frontmatter } = Astro.props
---
<Base {frontmatter}>
    <video
        id="hero"
        class="block h-auto w-full overflow-hidden"
        onloadedmetadata="this.muted=true"
        autoplay
        loop
        preload="auto"
    >
        <source src={`/2firespark4_a490727ca6.mp4`} type="video/mp4" />
        <track kind="captions" />
    </video>
    <div id="boxes" class="grid lg:grid-cols-3">
        <div class="relative flex min-w-0 justify-center bg-[url('/sermons.png')] bg-cover bg-center px-8 py-20 text-center before:absolute before:inset-0 before:bg-black/60 hover:after:opacity-100 after:absolute after:inset-x-0 after:bottom-0 after:h-[5px] after:bg-fogm-red after:opacity-0 after:transition">
            <div class="relative max-w-[300px]">
                <h1 class="my-6 font-display text-4xl uppercase">Live Sermons</h1>
                <p class="leading-[30px]">
                    Tune in daily to watch live sermons or scroll through our many
                    past sermons archived
                </p>
                <a href="./live-feed">
                    <button class="mt-3 inline-flex h-[46px] w-40 items-center justify-center rounded border-x-2 border-fogm-orange bg-[linear-gradient(to_right,#e4381C_100%,#e16521_100%),linear-gradient(to_right,#e4381C_0%,#e16521_0%)] bg-[length:100%_2px] bg-[position:0_0,0_100%] bg-no-repeat px-3 font-display text-sm font-semibold uppercase tracking-[2px] text-white transition hover:bg-[linear-gradient(to_right,#e4381C_100%,#e16521_100%),linear-gradient(to_right,#e4381C_0%,#e16521_0%),linear-gradient(to_right,#e16521,#e4381C)] hover:bg-[length:100%_2px,100%_2px,100%_100%] hover:bg-[position:0_0,0_100%,0_0]">Watch Now</button>
                </a>
            </div>
        </div>
        <div class="relative flex min-w-0 justify-center bg-[url('/dvd.jpg')] bg-cover bg-center px-8 py-20 text-center before:absolute before:inset-0 before:bg-black/60 hover:after:opacity-100 after:absolute after:inset-x-0 after:bottom-0 after:h-[5px] after:bg-fogm-red after:opacity-0 after:transition">
            <div class="relative max-w-[300px]">
                <h1 class="my-6 font-display text-4xl uppercase">Available DVDs</h1>
                <p class="leading-[30px]">
                    We offer 3 DVDs available in either English or Portuguese,
                    presented by Pastor David White
                </p>
                <a href="./order">
                    <button class="mt-3 inline-flex h-[46px] w-40 items-center justify-center rounded border-x-2 border-fogm-orange bg-[linear-gradient(to_right,#e4381C_100%,#e16521_100%),linear-gradient(to_right,#e4381C_0%,#e16521_0%)] bg-[length:100%_2px] bg-[position:0_0,0_100%] bg-no-repeat px-3 font-display text-sm font-semibold uppercase tracking-[2px] text-white transition hover:bg-[linear-gradient(to_right,#e4381C_100%,#e16521_100%),linear-gradient(to_right,#e4381C_0%,#e16521_0%),linear-gradient(to_right,#e16521,#e4381C)] hover:bg-[length:100%_2px,100%_2px,100%_100%] hover:bg-[position:0_0,0_100%,0_0]">Order Now</button>
                </a>
            </div>
        </div>
        <div class="relative flex min-w-0 justify-center bg-[url('/kenya.jpg')] bg-cover bg-center px-8 py-20 text-center before:absolute before:inset-0 before:bg-black/60 hover:after:opacity-100 after:absolute after:inset-x-0 after:bottom-0 after:h-[5px] after:bg-fogm-red after:opacity-0 after:transition">
            <div class="relative max-w-[300px]">
                <h1 class="my-6 font-display text-4xl uppercase">Reaching Out</h1>
                <p class="leading-[30px]">
                    Spreading the message, truth, and teachings of The Unknown God
                    throughout the globe
                </p>
                <a href="./contact-us"
                    ><button class="mt-3 inline-flex h-[46px] w-40 items-center justify-center rounded border-x-2 border-fogm-orange bg-[linear-gradient(to_right,#e4381C_100%,#e16521_100%),linear-gradient(to_right,#e4381C_0%,#e16521_0%)] bg-[length:100%_2px] bg-[position:0_0,0_100%] bg-no-repeat px-3 font-display text-sm font-semibold uppercase tracking-[2px] text-white transition hover:bg-[linear-gradient(to_right,#e4381C_100%,#e16521_100%),linear-gradient(to_right,#e4381C_0%,#e16521_0%),linear-gradient(to_right,#e16521,#e4381C)] hover:bg-[length:100%_2px,100%_2px,100%_100%] hover:bg-[position:0_0,0_100%,0_0]">Get Involved</button>
                </a>
            </div>
        </div>
    </div>
    <article class="py-12 leading-[30px] [&_a]:text-fogm-red [&_a:hover]:opacity-80 [&_audio]:w-full [&_figure]:mx-0 [&_h1]:my-9 [&_h1]:font-display [&_h1]:text-5xl [&_h1]:font-medium [&_h1]:uppercase [&_h2]:my-6 [&_h2]:font-display [&_h2]:text-4xl [&_h2]:uppercase [&_h3]:my-5 [&_h3]:font-display [&_h3]:text-3xl [&_h3]:uppercase [&_iframe]:max-w-full [&_iframe]:border-0 [&_img]:mx-auto [&_img]:my-4 [&_img]:h-auto [&_img]:max-w-full [&_li]:break-words [&_p]:break-words">
        <div class="mx-auto w-[min(1200px,calc(100%-48px))]">
            <slot />
        </div>
    </article>
</Base>

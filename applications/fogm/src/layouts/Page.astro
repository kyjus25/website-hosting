---
import Base from './Base.astro';
const { frontmatter } = Astro.props
---

<Base {frontmatter}>
    <section class="bg-[linear-gradient(45deg,#e16521,#e4381C)] pt-[clamp(120px,18vw,180px)] pb-[clamp(40px,8vw,70px)]">
        <div class="mx-auto w-[min(1200px,calc(100%-48px))]">
            <h1 class="m-0 font-display text-5xl uppercase">{frontmatter.title}</h1>
        </div>
    </section>
    <article class="py-12">
        <div class="prose prose-invert prose-stone mx-auto w-[min(1200px,calc(100%-48px))] max-w-none prose-headings:font-display prose-headings:uppercase prose-a:text-fogm-red hover:prose-a:opacity-80 prose-img:mx-auto prose-img:h-auto prose-img:max-w-full prose-figure:mx-0">
            <slot />
        </div>
    </article>
</Base>

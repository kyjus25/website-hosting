---
import Nav from "../../../../util/Nav.astro";
const posts = Object.values(import.meta.glob('../pages/**/*.md', { eager: true }));
---
<header class="absolute top-0 z-10 w-full py-5 font-display text-[15px]">
    <div class="mx-auto flex w-[min(1200px,calc(100%-48px))] flex-col items-center gap-4 lg:flex-row lg:justify-between">
      <div class="w-[200px] text-center lg:text-left">
        <a href="/" class="inline-flex min-h-11 min-w-11 items-center justify-center text-white hover:opacity-80">
          <i class="fas fa-cross" />
        </a>
      </div>
      <div class="min-w-0 flex-1 text-center">
        <Nav {posts} />
      </div>
      <div class="flex w-[150px] shrink-0 items-center justify-end gap-2 text-right text-[22px]">
        <a href="https://www.facebook.com/fogtvinternational" target="_blank" class="px-1 text-white hover:opacity-80">
          <i class="fab fa-facebook-square" />
        </a>
        <a href="https://twitter.com/FOG_TFH" target="_blank" class="px-1 text-white hover:opacity-80">
          <i class="fab fa-twitter-square" />
        </a>
        <a
          href="https://www.youtube.com/channel/UC3OLduBLDqPjW0AndY2yYrA"
          target="_blank"
          class="px-1 text-white hover:opacity-80"
        >
          <i class="fab fa-youtube-square" />
        </a>
        <a href="https://vimeo.com/fogtvinternational" target="_blank" class="px-1 text-white hover:opacity-80">
          <i class="fab fa-vimeo-square" />
        </a>
      </div>
    </div>
  </header>
